---
import Layout from "./Layout.astro";
import { render } from "astro:content";
export type Props = {
  entry: any;
};
const { entry } = Astro.props;
const { Content } = await render(entry);
---

<Layout title={entry.data.title}>
  <article class="max-w-3xl mx-auto px-6 py-24">
    <header class="mb-10">
      <a href="/blog" class="text-sm text-blue-600 dark:text-blue-400 hover:underline mb-4 inline-block">&larr; Back to blog</a>
      <h1 class="text-3xl font-bold text-gray-900 dark:text-white font-display">{entry.data.title}</h1>
      <p class="text-sm text-gray-500 dark:text-gray-400 mt-2">{entry.data.date.toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" })}</p>
    </header>
    <div class="prose prose-gray dark:prose-invert max-w-none">
      <Content />
    </div>
  </article>
</Layout>
