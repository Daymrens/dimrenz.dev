---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';

const repos = [
  {
    name: "BEERNEST-",
    desc: "A beer-themed project built with CSS",
    lang: "CSS",
    url: "https://github.com/Daymrens/BEERNEST-",
  },
  {
    name: "LendWUs",
    desc: "Flutter-based lending app",
    lang: "Dart",
    url: "https://github.com/Daymrens/LendWUs",
  },
  {
    name: "POS-SYSTEM-C-FINAL-PROJECT",
    desc: "Point of Sale system in C#",
    lang: "C#",
    url: "https://github.com/Daymrens/POS-SYSTEM-C-FINAL-PROJECT-2nd-Year-",
  },
  {
    name: "Dime-Renz---Portfolio",
    desc: "Previous portfolio version",
    lang: "HTML",
    url: "https://github.com/Daymrens/Dime-Renz---Portfolio",
  },
];
---

<Layout title="Projects">
  <Nav />
  <main class="min-h-screen pt-24 pb-16 px-6">
    <div class="max-w-4xl mx-auto">
      <h1 class="text-4xl font-bold mb-2">Projects</h1>
      <p class="text-gray-400 mb-10">Things I've built and contributed to.</p>
      <div class="grid gap-6">
        {repos.map((r) => (
          <a
            href={r.url}
            target="_blank"
            class="block border border-gray-800 rounded-xl p-6 hover:border-blue-500/50 hover:bg-gray-900/50 transition-all"
          >
            <div class="flex items-start justify-between gap-4">
              <div>
                <h2 class="text-xl font-semibold text-white mb-1">{r.name}</h2>
                <p class="text-gray-400 text-sm">{r.desc}</p>
              </div>
              <span class="shrink-0 text-xs font-mono text-blue-400 bg-blue-500/10 rounded-full px-3 py-1">{r.lang}</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </main>
</Layout>
