---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';

const res = await fetch("https://api.github.com/users/Daymrens/repos?sort=updated&per_page=50&type=public");
const repos = await res.json();

type Repo = {
  name: string;
  description: string | null;
  html_url: string;
  language: string | null;
  stargazers_count: number;
  fork: boolean;
  updated_at: string;
};

const langColors: Record<string, string> = {
  Dart: "bg-cyan-400 border-cyan-500/30 hover:border-cyan-400",
  "C#": "bg-purple-400 border-purple-500/30 hover:border-purple-400",
  CSS: "bg-blue-400 border-blue-500/30 hover:border-blue-400",
  HTML: "bg-orange-400 border-orange-500/30 hover:border-orange-400",
  JavaScript: "bg-yellow-400 border-yellow-500/30 hover:border-yellow-400",
  TypeScript: "bg-blue-500 border-blue-500/30 hover:border-blue-400",
  Python: "bg-green-400 border-green-500/30 hover:border-green-400",
};

const langDot: Record<string, string> = {
  Dart: "bg-cyan-400",
  "C#": "bg-purple-400",
  CSS: "bg-blue-400",
  HTML: "bg-orange-400",
  JavaScript: "bg-yellow-400",
  TypeScript: "bg-blue-500",
  Python: "bg-green-400",
};
---

<Layout title="Projects">
  <Nav />
  <main class="min-h-screen pt-24 pb-16 px-6">
    <div class="max-w-4xl mx-auto">
      <h1 class="text-4xl font-bold mb-2 font-display">Projects</h1>
      <p class="text-gray-400 mb-2">Things I've built and contributed to.</p>
      <p class="text-xs text-gray-600 mb-8">Auto-updated from GitHub.</p>
      <div class="grid gap-6 md:grid-cols-2">
        {repos.filter((r: Repo) => !r.fork).map((r: Repo, i: number) => (
          <a
            href={r.html_url}
            target="_blank"
            class={`group reveal block border rounded-xl p-6 transition-all duration-300 hover:-translate-y-1 ${langColors[r.language ?? ""] ?? "border-gray-800 hover:border-gray-600"}`}
            style={`animation-delay: ${i * 50}ms`}
          >
            <div class="flex items-start justify-between gap-4">
              <div class="min-w-0">
                <div class="flex items-center gap-2 mb-2">
                  <span class={`w-2.5 h-2.5 rounded-full ${langDot[r.language ?? ""] ?? "bg-gray-500"}`}></span>
                  <h2 class="text-xl font-semibold text-white group-hover:text-blue-300 transition-colors truncate">{r.name}</h2>
                </div>
                <p class="text-gray-400 text-sm line-clamp-2">{r.description ?? "No description"}</p>
              </div>
              <div class="flex items-center gap-2 shrink-0">
                {r.stargazers_count > 0 && (
                  <span class="text-xs text-gray-500">⭐ {r.stargazers_count}</span>
                )}
                <span class="text-xs font-mono text-gray-400 bg-gray-800 rounded-full px-3 py-1 group-hover:bg-gray-700 transition-colors">
                  {r.language ?? "N/A"}
                </span>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </main>
</Layout>
