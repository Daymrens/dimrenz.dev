---
import Layout from '../layouts/Layout.astro';
---

<Layout title="404 - Not Found">
  <main class="min-h-screen flex flex-col items-center justify-center px-6 text-center">
    <h1 class="text-8xl font-bold font-display text-transparent bg-clip-text bg-gradient-to-r from-blue-400 to-purple-500 mb-4">404</h1>
    <p class="text-xl text-gray-400 mb-2">This page doesn't exist.</p>
    <p class="text-sm text-gray-600 mb-8">Maybe you took a wrong turn?</p>
    <a
      href="/"
      class="px-6 py-3 rounded-full border border-gray-700 text-sm font-medium text-gray-300 hover:bg-blue-600 hover:border-blue-600 hover:text-white transition-all"
    >
      Go home
    </a>
  </main>
</Layout>
