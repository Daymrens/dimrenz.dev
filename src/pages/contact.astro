---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';

const links = [
  { label: "GitHub", href: "https://github.com/Daymrens", icon: "github" },
  { label: "LinkedIn", href: "https://www.linkedin.com/in/Dime Renz Apor/", icon: "linkedin" },
  { label: "YouTube", href: "https://www.youtube.com/@dimerenz", icon: "youtube" },
  { label: "Facebook", href: "https://facebook.com/daymrenss", icon: "facebook" },
  { label: "Instagram", href: "https://www.instagram.com/daymeeed/", icon: "instagram" },
];
---

<Layout title="Contact">
  <Nav />
  <main class="min-h-screen pt-24 pb-16 px-6 flex items-center justify-center">
    <div class="max-w-lg w-full text-center">
      <h1 class="text-4xl font-bold mb-2 font-display">Get in Touch</h1>
      <p class="text-gray-400 mb-10">
        Let's connect! Find me on any of these platforms.
      </p>
      <div class="flex flex-col gap-4">
        {links.map((l, i) => (
          <a
            href={l.href}
            target="_blank"
            class="reveal block border border-gray-800 rounded-xl px-6 py-4 text-white font-medium hover:border-blue-500/50 hover:bg-gray-900/50 hover:-translate-y-0.5 transition-all duration-300"
            style={`animation-delay: ${i * 80}ms`}
          >
            {l.label}
            <span class="inline-block ml-2 text-gray-500 group-hover:translate-x-1 transition-transform">&rarr;</span>
          </a>
        ))}
      </div>
    </div>
  </main>
</Layout>
