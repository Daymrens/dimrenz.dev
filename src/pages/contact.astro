---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';

const links = [
  { label: "GitHub", href: "https://github.com/Daymrens" },
  { label: "LinkedIn", href: "https://www.linkedin.com/in/Dime%20Renz%20Apor/" },
  { label: "YouTube", href: "https://www.youtube.com/@dimerenz" },
  { label: "Facebook", href: "https://facebook.com/daymrenss" },
  { label: "Instagram", href: "https://www.instagram.com/daymeeed/" },
];
---

<Layout title="Contact">
  <Nav />
  <main class="min-h-screen pt-24 pb-16 px-6 flex items-center justify-center">
    <div class="max-w-lg w-full text-center">
      <h1 class="text-4xl font-bold mb-2 font-display text-gray-900 dark:text-white">Get in Touch</h1>
      <p class="text-gray-500 dark:text-gray-400 mb-10">
        Let's connect! Find me on any of these platforms.
      </p>
      <div class="flex flex-col gap-4">
        {links.map((l, i) => (
          <a
            href={l.href}
            target="_blank"
            class="reveal block border border-gray-200 dark:border-gray-800 rounded-xl px-6 py-4 text-gray-700 dark:text-white font-medium hover:border-blue-500 hover:bg-blue-50 dark:hover:bg-gray-900/50 hover:-translate-y-0.5 transition-all duration-300 bg-white dark:bg-transparent"
            style={`animation-delay: ${i * 80}ms`}
          >
            {l.label}
            <span class="inline-block ml-2 text-gray-400 dark:text-gray-500">&rarr;</span>
          </a>
        ))}
      </div>

      <div class="mt-16 pt-8 border-t border-gray-200 dark:border-gray-800 reveal">
        <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-4">Or send a message</h2>
        <form action="https://formspree.io/f/xoveyjre" method="POST" class="text-left space-y-4">
          <div>
            <label for="name" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Name</label>
            <input type="text" id="name" name="name" required
              class="w-full px-4 py-2.5 rounded-lg border border-gray-300 dark:border-gray-700 bg-white dark:bg-gray-900 text-gray-900 dark:text-white focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition text-sm"
            />
          </div>
          <div>
            <label for="email" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Email</label>
            <input type="email" id="email" name="_replyto" required
              class="w-full px-4 py-2.5 rounded-lg border border-gray-300 dark:border-gray-700 bg-white dark:bg-gray-900 text-gray-900 dark:text-white focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition text-sm"
            />
          </div>
          <div>
            <label for="message" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Message</label>
            <textarea id="message" name="message" rows="4" required
              class="w-full px-4 py-2.5 rounded-lg border border-gray-300 dark:border-gray-700 bg-white dark:bg-gray-900 text-gray-900 dark:text-white focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition text-sm resize-none"
            ></textarea>
          </div>
          <button type="submit"
            class="w-full px-6 py-3 rounded-lg bg-blue-600 text-white font-medium hover:bg-blue-700 transition-colors text-sm"
          >
            Send message
          </button>
        </form>
      </div>
    </div>
  </main>
</Layout>
