---
const res = await fetch("https://api.github.com/users/Daymrens/repos?sort=updated&per_page=6&type=public");
const repos = await res.json();

type Repo = {
  name: string;
  description: string | null;
  html_url: string;
  language: string | null;
  stargazers_count: number;
  fork: boolean;
};

const langColors: Record<string, string> = {
  Dart: "bg-cyan-400",
  "C#": "bg-purple-400",
  CSS: "bg-blue-400",
  HTML: "bg-orange-400",
  JavaScript: "bg-yellow-400",
  TypeScript: "bg-blue-500",
  Python: "bg-green-400",
};
---

<section id="featured" class="py-24 px-6 bg-gray-50 dark:bg-gray-950/50">
  <div class="max-w-4xl mx-auto">
    <div class="flex items-end justify-between mb-10">
      <div>
        <h2 class="text-3xl font-bold font-display text-gray-900 dark:text-white reveal">Featured Projects</h2>
        <p class="text-gray-500 dark:text-gray-400 mt-2 reveal animate-delay-100">Pulled live from my GitHub.</p>
      </div>
      <a
        href="/projects"
        class="hidden md:inline-flex text-sm text-gray-500 dark:text-gray-400 hover:text-gray-900 dark:hover:text-white transition-colors reveal animate-delay-200"
      >
        View all &rarr;
      </a>
    </div>
    <div class="grid gap-6 md:grid-cols-3">
      {repos.filter((r: Repo) => !r.fork).slice(0, 6).map((r: Repo, i: number) => (
        <a
          href={r.html_url}
          target="_blank"
          class="reveal block border border-gray-200 dark:border-gray-800 rounded-xl p-5 hover:border-blue-500 hover:bg-blue-50 dark:hover:bg-gray-900/50 hover:-translate-y-1 transition-all duration-300 group bg-white dark:bg-transparent"
          style={`animation-delay: ${i * 100}ms`}
        >
          <div class="flex items-center gap-2 mb-3">
            <div class="w-8 h-8 rounded-lg bg-gradient-to-br from-blue-500 to-purple-500 flex items-center justify-center text-xs font-bold text-white">
              {r.name[0]}
            </div>
            <span class="text-sm font-medium text-gray-900 dark:text-white group-hover:text-blue-600 dark:group-hover:text-blue-300 transition-colors truncate">{r.name}</span>
          </div>
          <p class="text-sm text-gray-500 dark:text-gray-400 leading-relaxed line-clamp-2">{r.description ?? "No description"}</p>
          <div class="flex items-center gap-3 mt-4">
            {r.language && (
              <div class="flex items-center gap-1.5">
                <span class={`w-2 h-2 rounded-full ${langColors[r.language] ?? "bg-gray-500"}`}></span>
                <span class="text-xs text-gray-500">{r.language}</span>
              </div>
            )}
            {r.stargazers_count > 0 && (
              <span class="text-xs text-gray-500">⭐ {r.stargazers_count}</span>
            )}
          </div>
        </a>
      ))}
    </div>
    <div class="text-center mt-8 md:hidden">
      <a href="/projects" class="text-sm text-blue-600 dark:text-blue-400 hover:text-blue-500 transition-colors">View all projects &rarr;</a>
    </div>
  </div>
</section>
