---
const projects = [
  {
    name: "LendWUs",
    desc: "Flutter-based lending application with Firebase backend",
    lang: "Dart",
    url: "https://github.com/Daymrens/LendWUs",
  },
  {
    name: "POS System",
    desc: "Point of Sale system built with C# and .NET",
    lang: "C#",
    url: "https://github.com/Daymrens/POS-SYSTEM-C-FINAL-PROJECT-2nd-Year-",
  },
  {
    name: "BEERNEST-",
    desc: "A beer-themed CSS project",
    lang: "CSS",
    url: "https://github.com/Daymrens/BEERNEST-",
  },
];
---

<section id="featured" class="py-24 px-6 bg-gray-950/50">
  <div class="max-w-4xl mx-auto">
    <div class="flex items-end justify-between mb-10">
      <div>
        <h2 class="text-3xl font-bold font-display reveal">Featured Projects</h2>
        <p class="text-gray-400 mt-2 reveal animate-delay-100">Some things I've built recently.</p>
      </div>
      <a
        href="/projects"
        class="hidden md:inline-flex text-sm text-gray-400 hover:text-white transition-colors reveal animate-delay-200"
      >
        View all &rarr;
      </a>
    </div>
    <div class="grid gap-6 md:grid-cols-3">
      {projects.map((p, i) => (
        <a
          href={p.url}
          target="_blank"
          class="reveal block border border-gray-800 rounded-xl p-5 hover:border-blue-500/50 hover:bg-gray-900/50 hover:-translate-y-1 transition-all duration-300 group"
          style={`animation-delay: ${i * 100}ms`}
        >
          <div class="flex items-center gap-2 mb-3">
            <div class="w-8 h-8 rounded-lg bg-gradient-to-br from-blue-500 to-purple-500 flex items-center justify-center text-xs font-bold text-white">
              {p.name[0]}
            </div>
            <span class="text-sm font-medium text-white group-hover:text-blue-300 transition-colors">{p.name}</span>
          </div>
          <p class="text-sm text-gray-400 leading-relaxed">{p.desc}</p>
          <div class="flex items-center gap-2 mt-4">
            <span class="w-2 h-2 rounded-full bg-blue-400"></span>
            <span class="text-xs text-gray-500">{p.lang}</span>
          </div>
        </a>
      ))}
    </div>
    <div class="text-center mt-8 md:hidden">
      <a href="/projects" class="text-sm text-blue-400 hover:text-blue-300 transition-colors">View all projects &rarr;</a>
    </div>
  </div>
</section>
