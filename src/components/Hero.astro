---
const socials = [
  { label: "GitHub", href: "https://github.com/Daymrens" },
  { label: "LinkedIn", href: "https://www.linkedin.com/in/Dime Renz Apor/" },
  { label: "YouTube", href: "https://www.youtube.com/@dimerenz" },
  { label: "Facebook", href: "https://facebook.com/daymrenss" },
];

const roles = ["CS Student", "Developer", "Musician"];
---

<section class="relative min-h-screen flex flex-col justify-center items-center px-6 text-center overflow-hidden">
  <div class="absolute inset-0 overflow-hidden pointer-events-none">
    <div class="absolute top-1/4 left-1/4 w-72 h-72 bg-blue-500/10 rounded-full blur-3xl animate-pulse-glow"></div>
    <div class="absolute bottom-1/4 right-1/4 w-96 h-96 bg-purple-500/10 rounded-full blur-3xl animate-pulse-glow" style="animation-delay: 1.5s"></div>
    <div class="absolute top-1/3 right-1/3 w-48 h-48 bg-cyan-500/10 rounded-full blur-3xl animate-pulse-glow" style="animation-delay: 3s"></div>
    {[1,2,3,4,5,6].map((i) => (
      <div
        class="absolute w-1 h-1 bg-blue-400/30 rounded-full animate-float"
        style={{
          left: `${10 + i * 15}%`,
          top: `${20 + (i * 7) % 60}%`,
          animationDelay: `${i * 0.7}s`,
          animationDuration: `${4 + i * 0.5}s`,
        }}
      ></div>
    ))}
  </div>

  <div class="max-w-2xl relative z-10">
    <p class="text-blue-400 font-medium text-sm tracking-widest uppercase mb-4 reveal">CS Student & Developer</p>
    <h1 class="text-5xl md:text-7xl font-extrabold tracking-tight mb-6 font-display">
      Dime Renz
      <span class="text-transparent bg-clip-text bg-gradient-to-r from-blue-400 via-purple-400 to-cyan-400">Apor</span>
    </h1>
    <div class="h-8 mb-8">
      <span class="text-lg md:text-xl text-gray-400 font-mono animate-typing max-w-fit">
        {roles.join(" | ")}
      </span>
    </div>
    <p class="text-lg md:text-xl text-gray-400 leading-relaxed mb-8 reveal animate-delay-200">
      BSCS at Asian College of Technology.<br />
      Building software, making music, and always learning.
    </p>
    <div class="flex flex-wrap justify-center gap-3 reveal animate-delay-300">
      {socials.map((s) => (
        <a
          href={s.href}
          target="_blank"
          class="px-5 py-2.5 rounded-full border border-gray-700 text-sm font-medium text-gray-300 hover:bg-blue-600 hover:border-blue-600 hover:text-white hover:shadow-lg hover:shadow-blue-600/25 transition-all duration-300"
        >
          {s.label}
        </a>
      ))}
    </div>
  </div>

  <a href="#about" class="absolute bottom-10 text-gray-500 hover:text-gray-300 transition-colors animate-bounce">
    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"/></svg>
  </a>
</section>
