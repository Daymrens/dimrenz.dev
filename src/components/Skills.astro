---
const skills = [
  { name: "HTML/CSS", level: "Advanced" },
  { name: "Tailwind CSS", level: "Advanced" },
  { name: "Bootstrap", level: "Advanced" },
  { name: "JavaScript", level: "Intermediate" },
  { name: "TypeScript", level: "Intermediate" },
  { name: "C# / .NET", level: "Intermediate" },
  { name: "Python", level: "Intermediate" },
  { name: "Firebase", level: "Intermediate" },
  { name: "Flutter / Dart", level: "Intermediate" },
  { name: "Figma", level: "Intermediate" },
  { name: "Git / GitHub", level: "Advanced" },
  { name: "Linux", level: "Intermediate" },
];
---

<section id="skills" class="py-24 px-6">
  <div class="max-w-4xl mx-auto">
    <h2 class="text-3xl font-bold text-center mb-12 font-display reveal">Tools & Technologies</h2>
    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4">
      {skills.map((s, i) => (
        <div
          class="reveal border border-gray-800 rounded-xl p-4 text-center hover:border-blue-500/50 hover:bg-gray-900/50 hover:-translate-y-1 transition-all duration-300"
          style={`animation-delay: ${i * 50}ms`}
        >
          <p class="font-semibold text-white">{s.name}</p>
          <p class="text-xs text-gray-500 mt-1">{s.level}</p>
        </div>
      ))}
    </div>
  </div>
</section>
