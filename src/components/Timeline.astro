---
const events = [
  {
    year: "2025",
    title: "LendWUs",
    subtitle: "Flutter-based lending app",
    desc: "Built a mobile lending application using Flutter and Firebase.",
  },
  {
    year: "2024",
    title: "POS System",
    subtitle: "C# .NET Desktop Application",
    desc: "Developed a full Point of Sale system as a final project.",
  },
  {
    year: "2024",
    title: "BSCS (Undergrad)",
    subtitle: "Asian College of Technology",
    desc: "Studied Computer Science. Continued building projects independently.",
  },
  {
    year: "2023",
    title: "Started Coding",
    subtitle: "First lines of code",
    desc: "Began learning HTML, CSS, and C#. Built first portfolio site.",
  },
];
---

<section id="timeline" class="py-24 px-6">
  <div class="max-w-3xl mx-auto">
    <h2 class="text-3xl font-bold text-center mb-12 font-display text-gray-900 dark:text-white reveal">Timeline</h2>
    <div class="relative">
      <div class="absolute left-4 md:left-1/2 top-0 bottom-0 w-px bg-gray-200 dark:bg-gray-800 md:-translate-x-px"></div>
      {events.map((e, i) => (
        <div class={`reveal relative flex items-start gap-6 mb-10 md:mb-12 ${i % 2 === 0 ? "md:flex-row" : "md:flex-row-reverse"}`} style={`animation-delay: ${i * 100}ms`}>
          <div class="hidden md:block md:w-1/2"></div>
          <div class="absolute left-4 md:left-1/2 w-3 h-3 rounded-full bg-blue-600 dark:bg-blue-400 border-2 border-white dark:border-gray-950 -translate-x-1.5 md:-translate-x-1.5 mt-1.5 z-10"></div>
          <div class="ml-10 md:ml-0 md:w-1/2 md:px-6">
            <span class="text-xs font-mono text-blue-600 dark:text-blue-400">{e.year}</span>
            <h3 class="text-lg font-semibold text-gray-900 dark:text-white mt-0.5">{e.title}</h3>
            <p class="text-sm text-gray-500 dark:text-gray-400">{e.subtitle}</p>
            <p class="text-sm text-gray-500 dark:text-gray-400 mt-1 leading-relaxed">{e.desc}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
